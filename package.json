{
  "name": "youtube-tracker",
  "version": "1.0.0",
  "description": "A browser extension that automatically tracks your viewing progress on YouTube videos and resumes playback from where you left off.",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/franverona/youtube-tracker.git"
  },
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "vitest run",
    "type-check": "wxt prepare && tsc --noEmit",
    "lint": "eslint src",
    "postinstall": "wxt prepare && husky",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@wxt-dev/module-react": "^1.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "wxt": "^0.20.0"
  },
  "engines": {
    "node": ">=22.15.1"
  }
}
